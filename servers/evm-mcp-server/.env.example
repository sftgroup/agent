# EVM MCP Server 环境变量
# 到服务器后: cp .env.example .env && vim .env

# === RPC（必须用商业节点）===
ETH_RPC="https://eth-mainnet.g.alchemy.com/v2/YOUR_KEY"
BSC_RPC="https://bsc-mainnet.infura.io/v3/YOUR_KEY"
BASE_RPC="https://base-mainnet.g.alchemy.com/v2/YOUR_KEY"
POLYGON_RPC="https://polygon-mainnet.g.alchemy.com/v2/YOUR_KEY"
ARB_RPC="https://arb-mainnet.g.alchemy.com/v2/YOUR_KEY"
SEPOLIA_RPC="https://sepolia.infura.io/v3/YOUR_KEY"

# === 部署者私钥（支持多链多私钥）===
# 默认私钥（所有链共用）
PRIVATE_KEY="***"
# 按链覆盖（优先级高于 PRIVATE_KEY）
# PRIVATE_KEY_ETH="***"
# PRIVATE_KEY_BSC="***"
# PRIVATE_KEY_BASE="***"
# PRIVATE_KEY_POLYGON="***"
# PRIVATE_KEY_ARB="***"

# === 浏览器 API key ===
ETHERSCAN_API_KEY="***"
BSCSCAN_API_KEY="***"
BASESCAN_API_KEY="***"
POLYGONSCAN_API_KEY="***"
ARBISCAN_API_KEY="***"

# === MCP Server ===
# API_Token header 认证（可选，内网可不设）
# API_TOKEN="***"
PORT=3400

# === DB ===
DB_PATH="./state.db"

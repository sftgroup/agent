{
  "agents": {
    "defaults": {
      "workspace": "/home/ubuntu/.openclaw/workspace",
      "sandbox": {
        "browser": {
          "enabled": false
        }
      },
      "model": {
        "primary": "deepseek/deepseek-v4-pro"
      },
      "skipOptionalBootstrapFiles": [
        "SOUL.md",
        "HEARTBEAT.md",
        "IDENTITY.md",
        "USER.md"
      ],
      "contextInjection": "always",
      "bootstrapMaxChars": 20000,
      "bootstrapTotalMaxChars": 50000,
      "subagents": {
        "allowAgents": [
          "*"
        ],
        "maxConcurrent": 5,
        "maxSpawnDepth": 2,
        "maxChildrenPerAgent": 10,
        "runTimeoutSeconds": 600,
        "archiveAfterMinutes": 60
      },
      "timeoutSeconds": 600,
      "maxConcurrent": 4,
      "contextTokens": 1000000,
      "compaction": {
        "reserveTokens": 12000,
        "keepRecentTokens": 20000,
        "maxHistoryShare": 0.6,
        "recentTurnsPreserve": 3,
        "notifyUser": true
      },
      "mediaMaxMb": 200,
      "memorySearch": {
        "provider": "openai",
        "model": "text-embedding-v4",
        "sources": [
          "memory"
        ]
      },
      "params": {
        "cacheRetention": "long"
      },
      "heartbeat": {
        "every": "55m"
      },
      "contextPruning": {
        "mode": "cache-ttl",
        "ttl": "1h"
      }
    },
    "list": [
      {
        "id": "team3",
        "default": true,
        "name": "team3 - Build Team",
        "description": "team3 — 全栈开发团队：需求分析、架构设计、任务调度、部署。使用 DeepSeek V4 Pro",
        "model": {
          "primary": "deepseek/deepseek-v4-pro"
